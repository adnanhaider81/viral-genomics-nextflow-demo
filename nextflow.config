params.reads = "${projectDir}/test_data/reads/*_R1.fastq"
params.reference = "${projectDir}/test_data/reference/toy_virus.fasta"
params.outdir = "results"
params.min_depth = 1
params.container = "viral-genomics-nextflow-demo:latest"
params.apptainer_container = "${projectDir}/containers/viral-genomics-nextflow-demo.sif"
params.queue = "short"

includeConfig 'conf/base.config'

profiles {
    docker {
        includeConfig 'conf/docker.config'
    }
    apptainer {
        includeConfig 'conf/apptainer.config'
    }
    slurm {
        includeConfig 'conf/slurm.config'
    }
}
